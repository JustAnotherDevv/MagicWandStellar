# ── LLM (required) ────────────────────────────────────────────────────────────
# MiniMax API key — https://platform.minimax.io
MINIMAX_API_KEY=sk-api-...

# MiniMax model (default: MiniMax-M2.7)
# MODEL=MiniMax-M2.7

# ── Stellar agent wallet (required for payment features) ──────────────────────
# Generate at https://laboratory.stellar.org/#account-creator or via Stellar CLI
# Fund testnet wallet: https://friendbot.stellar.org/?addr=<YOUR_PUBLIC_KEY>
# Fund with USDC: https://laboratory.stellar.org (Asset: USDC, Issuer: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN)
STELLAR_SECRET_KEY=S...
STELLAR_PUBLIC_KEY=G...

# Stellar network (testnet or mainnet)
STELLAR_NETWORK=testnet

# ── MPP payment middleware (optional) ─────────────────────────────────────────
# When MPP_ENABLED=true, POST /chat requires 0.01 USDC per request (MPP charge)
# Clients get a 402 + WWW-Authenticate challenge; pay with any MPP-compatible wallet
MPP_ENABLED=false
MPP_AMOUNT_USDC=0.01
# Random secret for HMAC-binding MPP challenges (generate: openssl rand -hex 32)
MPP_SECRET_KEY=change-this-to-a-random-secret-in-production

# ── x402 facilitator (optional override) ─────────────────────────────────────
# Default: https://www.x402.org/facilitator (Coinbase public testnet facilitator)
X402_FACILITATOR_URL=https://www.x402.org/facilitator

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
